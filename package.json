{
  "name": "wikimem",
  "version": "0.8.1",
  "description": "Self-improving wiki IDE. Ingest anything (13 formats), query with any LLM, three automations: ingest, scrape, improve.",
  "type": "module",
  "bin": {
    "wikimem": "./dist/index.js",
    "wikimem-mcp": "./dist/mcp-entry.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/web/public/",
    "scripts/",
    "templates/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js && rm -rf dist/web/public && cp -r src/web/public dist/web/ 2>/dev/null || true",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "obsidian",
    "ai",
    "agent",
    "markdown",
    "self-improving",
    "rag-alternative",
    "karpathy",
    "personal-wiki",
    "claude",
    "openai",
    "ollama"
  ],
  "author": "Naman Parikh <naman10parikh@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@clack/prompts": "^1.2.0",
    "adm-zip": "^0.5.17",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "openai": "^4.80.0",
    "ora": "^8.1.0",
    "pdf-parse": "1.1.1",
    "simple-git": "^3.35.2",
    "xlsx": "^0.18.5",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
