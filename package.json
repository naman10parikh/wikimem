{
  "name": "llmwiki",
  "version": "0.1.0",
  "description": "Build self-improving knowledge bases with LLMs. Ingest anything, query everything, auto-evolve.",
  "type": "module",
  "bin": {
    "llmwiki": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "llm",
    "wiki",
    "knowledge-base",
    "obsidian",
    "ai",
    "agent",
    "markdown",
    "self-improving",
    "rag-alternative",
    "karpathy",
    "personal-wiki",
    "claude",
    "openai",
    "ollama"
  ],
  "author": "Naman Parikh <naman10parikh@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^13.0.0",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "mammoth": "^1.12.0",
    "node-cron": "^3.0.3",
    "openai": "^4.80.0",
    "ora": "^8.1.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
