{
  "$schema": "https://energy.dev/schemas/theme-tokens.json",
  "name": "{{AGENT_NAME}}",
  "version": "1.0.0",
  "vertical": "{{VERTICAL}}",
  "colors": {
    "brand": {
      "50": "{{BRAND_50}}",
      "100": "{{BRAND_100}}",
      "200": "{{BRAND_200}}",
      "300": "{{BRAND_300}}",
      "400": "{{BRAND_400}}",
      "500": "{{BRAND_500}}",
      "600": "{{BRAND_600}}",
      "700": "{{BRAND_700}}",
      "800": "{{BRAND_800}}",
      "900": "{{BRAND_900}}",
      "950": "{{BRAND_950}}"
    },
    "accent": "{{ACCENT_HEX}}",
    "surface": {
      "primary": "#141312",
      "secondary": "#0a0a0a",
      "card": "rgba(255,255,255,0.03)",
      "cardHover": "rgba(255,255,255,0.06)",
      "overlay": "rgba(255,255,255,0.09)",
      "highlight": "rgba(255,255,255,0.12)"
    },
    "text": {
      "primary": "#e5e5e5",
      "secondary": "#a3a3a3",
      "muted": "rgba(255,255,255,0.3)",
      "inverse": "#141312",
      "brand": "{{BRAND_400}}"
    },
    "border": {
      "default": "rgba(255,255,255,0.06)",
      "active": "rgba({{BRAND_RGB}},0.3)",
      "error": "rgba(239,68,68,0.3)"
    },
    "semantic": {
      "success": "#10B981",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#3B82F6"
    }
  },
  "typography": {
    "display": {
      "family": "{{DISPLAY_FONT}}",
      "fallback": "Georgia, Cambria, 'Times New Roman', serif",
      "weights": [400, 700],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family={{DISPLAY_FONT_ENCODED}}:wght@400;700&display=swap"
    },
    "body": {
      "family": "{{BODY_FONT}}",
      "fallback": "system-ui, -apple-system, sans-serif",
      "weights": [400, 500, 600, 700],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family={{BODY_FONT_ENCODED}}:wght@400;500;600;700&display=swap"
    },
    "code": {
      "family": "{{MONO_FONT}}",
      "fallback": "Menlo, Monaco, Consolas, monospace",
      "weights": [400],
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family={{MONO_FONT_ENCODED}}:wght@400&display=swap"
    },
    "scale": {
      "display": {
        "size": "2rem",
        "weight": 400,
        "lineHeight": 1.2,
        "letterSpacing": "-0.01em"
      },
      "h1": {
        "size": "1.5rem",
        "weight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "-0.005em"
      },
      "h2": {
        "size": "1.25rem",
        "weight": 600,
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "h3": {
        "size": "1.125rem",
        "weight": 500,
        "lineHeight": 1.4,
        "letterSpacing": "0"
      },
      "body": {
        "size": "0.875rem",
        "weight": 400,
        "lineHeight": 1.6,
        "letterSpacing": "0.01em"
      },
      "small": {
        "size": "0.75rem",
        "weight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0.02em"
      },
      "code": {
        "size": "0.8125rem",
        "weight": 400,
        "lineHeight": 1.5,
        "letterSpacing": "0"
      }
    },
    "scaleRatio": "{{SCALE_RATIO}}"
  },
  "spacing": {
    "unit": 8,
    "scale": {
      "0.5": "4px",
      "1": "8px",
      "1.5": "12px",
      "2": "16px",
      "3": "24px",
      "4": "32px",
      "6": "48px",
      "8": "64px",
      "10": "80px",
      "12": "96px",
      "16": "128px"
    }
  },
  "borderRadius": {
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "20px",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px rgba(0,0,0,0.3)",
    "md": "0 4px 6px rgba(0,0,0,0.3)",
    "lg": "0 10px 15px rgba(0,0,0,0.3)",
    "xl": "0 20px 25px rgba(0,0,0,0.3)",
    "2xl": "0 25px 50px rgba(0,0,0,0.4)",
    "brand": "0 4px 14px rgba({{BRAND_RGB}},0.25)"
  },
  "animation": {
    "microInteraction": "100-200ms",
    "feedback": "200-300ms",
    "transition": "200-500ms",
    "entrance": "300-500ms",
    "staggerDelay": "50ms",
    "ambient": "2-4s",
    "easing": {
      "entrance": "cubic-bezier(0, 0, 0.2, 1)",
      "exit": "cubic-bezier(0.4, 0, 1, 1)",
      "interactive": "cubic-bezier(0.25, 0.1, 0.25, 1)",
      "ambient": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "personality": {
    "keywords": [
      "{{KEYWORD_1}}",
      "{{KEYWORD_2}}",
      "{{KEYWORD_3}}",
      "{{KEYWORD_4}}",
      "{{KEYWORD_5}}"
    ],
    "movement": "{{MOVEMENT_QUALITY}}",
    "material": "{{MATERIAL_QUALITY}}",
    "symbolism": "{{SYMBOLIC_MEANING}}"
  }
}
